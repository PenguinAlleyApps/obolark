# Obolark · .env.local.example
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# ========== Circle (required) ==========
CIRCLE_API_KEY=                 # From console.circle.com → API keys
CIRCLE_ENTITY_SECRET=           # Generated by scripts/00-register-entity-secret.ts (32-byte hex)

# ========== Arc testnet ==========
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# ========== Facilitators ==========
OBOLARK_FACILITATOR=circle       # primary: 'circle' · secondary (Day 2): 'thirdweb'
THIRDWEB_CLIENT_ID=              # Delta A — only if OBOLARK_FACILITATOR=thirdweb

# ========== External x402 sellers ==========
AISA_API_KEY=                    # Delta B — AISA.one pass-through for Radar agent

# ========== App ==========
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info                   # pino levels: trace|debug|info|warn|error|fatal
